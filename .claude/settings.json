{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/session-start.sh\"",
            "timeout": 10,
            "statusMessage": "Loading governance checklist"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/require-story.sh\"",
            "timeout": 10,
            "statusMessage": "Governance: requirements-first check"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/git-gate.sh\"",
            "timeout": 10,
            "statusMessage": "Governance: git gate"
          }
        ]
      }
    ]
  }
}
